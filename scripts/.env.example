# AI Thực Chiến Facebook Autoposter Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# FACEBOOK CONFIGURATION
# ============================================================================
# Get these from https://developers.facebook.com/

# Your Facebook Page ID (numeric ID, not the page name)
# How to find it: Visit your page, the URL is facebook.com/[PAGE_NAME]
# Then use the Graph API explorer to get the numeric ID
FACEBOOK_PAGE_ID=

# Long-lived access token for your page
# How to get it:
# 1. Go to https://developers.facebook.com/apps/
# 2. Create an app (type: Business)
# 3. Get a user token with pages_manage_posts, pages_read_engagement scopes
# 4. Convert it to a long-lived token
# Note: Tokens expire - refresh them before they expire
FACEBOOK_ACCESS_TOKEN=

# ============================================================================
# CLAUDE API CONFIGURATION
# ============================================================================
# Get from https://console.anthropic.com/

# Your Anthropic API key for Claude
CLAUDE_API_KEY=

# ============================================================================
# TAVILY API CONFIGURATION
# ============================================================================
# Get from https://tavily.com/

# Your Tavily API key for searching AI news
TAVILY_API_KEY=

# ============================================================================
# OPTIONAL: POSTING SCHEDULE
# ============================================================================
# You can customize these if needed:

# Posting window start hour (Vietnam time, GMT+7)
# Default: 13 (1pm)
# POST_WINDOW_START=13

# Posting window end hour (Vietnam time, GMT+7)
# Default: 16 (4pm)
# POST_WINDOW_END=16

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# 1. Make sure all API keys are correct
# 2. Test the script manually first: python facebook-autoposter.py --run-once
# 3. Check logs in ../logs/ directory
# 4. Run health check: bash health-check.sh
