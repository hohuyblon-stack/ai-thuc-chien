# ============================================================================
# AI Thực Chiến — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ============================================================================
# CORE API KEYS (required for all pipelines)
# ============================================================================

# Claude API Key (from https://console.anthropic.com)
# Used for: script generation, caption writing, content creation
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily API Key (from https://tavily.com)
# Used for: AI news fetching (fallback: RSS feeds)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Replicate API Token (from https://replicate.com/account/api-tokens)
# Used for: SadTalker avatar generation (~$0.05/video)
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# FACEBOOK (text post autoposter)
# ============================================================================
# Create a Meta Developer App at https://developers.facebook.com
# Required permissions: pages_manage_posts, pages_read_engagement
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# ============================================================================
# YOUTUBE (video pipeline — OAuth2)
# ============================================================================
# 1. Create project at https://console.cloud.google.com
# 2. Enable YouTube Data API v3
# 3. Create OAuth2 credentials (Desktop app)
# 4. Download credentials.json to project root
# 5. Run: python3 scripts/youtube-uploader.py --auth
# Token will be saved to youtube_token.json automatically
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ============================================================================
# TIKTOK (video pipeline — Content Posting API v2)
# ============================================================================
# 1. Create app at https://developers.tiktok.com
# 2. Apply for Content Posting API access
# 3. Get access token via OAuth2 flow
TIKTOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
